<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.skcapstone.cloud9-daemon</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/node</string>
    <string>daemon/cloud9-daemon.js</string>
    <string>--config</string>
    <string>daemon/config.json</string>
  </array>

  <key>WorkingDirectory</key>
  <string>${HOME}/clawd/skcapstone-repos/cloud9</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>NODE_ENV</key>
    <string>production</string>
    <key>PATH</key>
    <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
  </dict>

  <key>ThrottleInterval</key>
  <integer>10</integer>

  <key>StandardOutPath</key>
  <string>${HOME}/.openclaw/logs/cloud9-daemon.stdout.log</string>
  <key>StandardErrorPath</key>
  <string>${HOME}/.openclaw/logs/cloud9-daemon.stderr.log</string>
</dict>
</plist>
